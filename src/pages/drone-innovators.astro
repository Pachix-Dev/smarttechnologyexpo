---
// src/pages/drone-innovators.astro
import Layout from '../layouts/Layout.astro'
import SegmentoLayout from '../layouts/SegmentoLayout.astro'
import { useTranslations, getTranslation } from '../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations(Astro.props, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)
---

<Layout
  title="Drone Innovators Forum — Smart Technology Expo 2026"
  description="Descubre el Drone Innovators Forum en Smart Technology Expo 2026."
>
  <SegmentoLayout
    titulo="Drone Innovators Forum"
    descripcion={tr('home.new_cap', 'Próximamente información sobre este segmento.')}
    icono="/img/segmentos/Drone_Innovators.webp"
    proximamente={true}
    expositoresBuscados={[]}
  />
</Layout>