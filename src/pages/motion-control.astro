---
// src/pages/motion-control.astro
import Layout from '../layouts/Layout.astro'
import SegmentoLayout from '../layouts/SegmentoLayout.astro'
import { useTranslations, getTranslation } from '../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations(Astro.props, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)
---

<Layout
  title="Motion Control y Sistemas de Accionamiento — Smart Technology Expo 2026"
  description="Descubre el segmento de Motion Control en Smart Technology Expo 2026."
>
  <SegmentoLayout
    titulo="Motion Control y Sistemas de Accionamiento"
    descripcion={tr('segments.desc_motion', '')}
    icono="/img/segmentos/Motion_Control_Sistemas_De_Accionamiento.webp"
    proximamente={true}
    expositoresBuscados={[]}
  />
</Layout>