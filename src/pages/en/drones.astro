---
// src/pages/en/drone-innovators.astro
import Layout from '../../layouts/Layout.astro'
import SegmentoLayout from '../../layouts/SegmentoLayout.astro'
import { useTranslations, getTranslation } from '../../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations({ locale: 'en' }, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)
---

<Layout
  title="Drones — Smart Technology Expo 2026"
  description="Discover the Drones segment at Smart Technology Expo 2026."
>
  <SegmentoLayout
    locale="en"
    titulo="Drones"
    descripcion={tr('segments.desc_drone', '')}
    icono="/img/segmentos/Drone_Innovators.webp"
    proximamente={true}
    expositoresBuscados={[]}
    factSheetEs="/files/factsheet_drone_inno_ators_2026_esp.pdf"
    factSheetEn="/files/factsheet_drone_inno_ators_2026_eng.pdf"
  />
</Layout>
