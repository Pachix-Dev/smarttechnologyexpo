---
// src/pages/en/motion-control.astro
import Layout from '../../layouts/Layout.astro'
import SegmentoLayout from '../../layouts/SegmentoLayout.astro'
import { useTranslations, getTranslation } from '../../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations({ locale: 'en' }, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)
---

<Layout
  title="Motion Control and Drive Systems — Smart Technology Expo 2026"
  description="Discover the Motion Control segment at Smart Technology Expo 2026."
>
  <SegmentoLayout
    locale="en"
    titulo="Motion Control and Drive Systems"
    descripcion={tr('segments.desc_motion', '')}
    icono="/img/segmentos/Motion_Control_Sistemas_De_Accionamiento.webp"
    proximamente={true}
    expositoresBuscados={[]}
  />
</Layout>