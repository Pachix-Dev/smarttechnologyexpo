---
// src/pages/automatizacion-robotica.astro
import Layout from '../layouts/Layout.astro'
import SegmentoLayout from '../layouts/SegmentoLayout.astro'
import { useTranslations, getTranslation } from '../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations(Astro.props, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)
---

<Layout
  title="Automatización y Robótica — Smart Technology Expo 2026"
  description="Descubre el segmento de Automatización y Robótica en Smart Technology Expo 2026."
>
  <SegmentoLayout
    titulo="Automatización y Robótica"
    descripcion={tr('segments.desc_automatizacion', '')}
    icono="/img/segmentos/Automatizacion_Robótica.webp"
    proximamente={true}
    expositoresBuscados={[]}
  />
</Layout>