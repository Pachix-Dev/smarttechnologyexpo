---
// src/pages/software-automatizacion.astro
import Layout from '../layouts/Layout.astro'
import SegmentoLayout from '../layouts/SegmentoLayout.astro'
import { useTranslations, getTranslation } from '../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations(Astro.props, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)
---

<Layout
  title="Software de Automatización e Integración de Sistemas — Smart Technology Expo 2026"
  description="Descubre el segmento de Software de Automatización en Smart Technology Expo 2026."
>
  <SegmentoLayout
    titulo="Software de Automatización e Integración de Sistemas"
    descripcion={tr('home.new_cap', 'Próximamente información sobre este segmento.')}
    icono="/img/segmentos/Software_Automatización.webp"
    proximamente={true}
    expositoresBuscados={[]}
  />
</Layout>