---
import { RegisterForm } from "./RegisterForm";

import { useTranslations, getTranslation } from "../../utils/translations";
import { ContactForm } from "../formExpositores/ContactForm";

const { locale, translations } = await useTranslations(Astro.props, Astro);

const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);

// Toma las traducciones del bloque "register"; si no existen, usa un objeto vacío para evitar errores.
const registerTranslations = translations?.register ?? {}; 
const currentLanguage = locale;
---

<div class="registro-visitante-home">
  <div class="header py-8 text-center">
    <h2 class="text-2xl sm:text-6xl font-extrabold">{locale === 'en' ? 'VISITOR REGISTRATION' : 'REGISTRO DE VISITANTE'}</h2>
    <span class="text-base sm:text-2xl mt-2 text-gray-600">
      {locale === 'en' ? 'Complete the form to register as a visitor for the event.' : 'Completa el formulario para registrarte como visitante en el evento.'}
    </span>
  </div>
  <div class="container mx-auto p-4 sm:p-20">
    <RegisterForm
      translates={registerTranslations}
      currentLanguage={currentLanguage}
      client:only="react"
    />
  </div>
</div>
