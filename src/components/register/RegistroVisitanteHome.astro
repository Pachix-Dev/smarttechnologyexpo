---
import { RegisterForm } from "./RegisterForm";
import OtherSectorProfileNotice from "./OtherSectorProfileNotice.astro";
import { useTranslations } from "../../utils/translations";

const { locale, translations } = await useTranslations(Astro.props, Astro);

// Toma las traducciones del bloque "register"; si no existen, usa un objeto vacio para evitar errores.
const registerTranslations = translations?.register ?? {};
const currentLanguage = locale;
---

<div class="registro-visitante-home">
  <div class="header pt-16 text-center">
    <h2 class="text-2xl sm:text-6xl font-extrabold">
      {locale === "en" ? "VISITOR REGISTRATION" : "REGISTRO DE VISITANTE"}
    </h2>
    <span class="mt-2 text-base text-gray-600 sm:text-2xl">
      {
        locale === "en"
          ? "Complete the form to register as a visitor for the event."
          : "Completa el formulario para registrarte como visitante en el evento."
      }
    </span>
  </div>

  <div class="container mx-auto p-4 sm:px-20">
    <OtherSectorProfileNotice locale={locale} />

    <RegisterForm
      translates={registerTranslations}
      currentLanguage={currentLanguage}
      client:only="react"
    />
  </div>
</div>
