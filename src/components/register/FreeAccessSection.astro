---
import { useTranslations, getTranslation } from "../../utils/translations";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);

// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);

const base = locale === "en" ? "/en" : "";
---
<section aria-labelledby="free-access-title" class="p-4">
  <div class="free-access-shell">
    
    <!-- sección de beneficios de acceso gratuito -->
    <div class="benefits-card h-full flex flex-col justify-center">
      <h2 id="free-access-title" class="benefits-title text-center sm:text-start uppercase">
        {tr("registerHome.freeAccess.title")}
      </h2>
      <div class="benefits-list">
        <article class="benefit-item">
          <span class="benefit-icon" aria-hidden="true">
            <img src="/img/check_icon.svg" alt="">
          </span>
          <div class="text-sm">
            <h3>{tr("registerHome.freeAccess.benefits.exhibition.title")}</h3>
            <p>{tr("registerHome.freeAccess.benefits.exhibition.description")}</p>
          </div>
        </article>

        <article class="benefit-item">
          <span class="benefit-icon" aria-hidden="true">
            <img src="/img/check_icon.svg" alt="">
          </span>
          <div class="text-sm">
            <h3>{tr("registerHome.freeAccess.benefits.conferences.title")}</h3>
            <p>{tr("registerHome.freeAccess.benefits.conferences.description")}</p>
          </div>
        </article>

        <!-- <article class="benefit-item">
          <span class="benefit-icon" aria-hidden="true">
            <img src="/img/check_icon.svg" alt="">
          </span>
          <div class="text-sm">
            <h3>{tr("registerHome.freeAccess.benefits.workshops.title")}</h3>
            <p>{tr("registerHome.freeAccess.benefits.workshops.description")}</p>
          </div>
        </article> -->

        <article class="benefit-item">
          <span class="benefit-icon" aria-hidden="true">
            <img src="/img/check_icon.svg" alt="">
          </span>
          <div class="text-sm">
            <h3>{tr("registerHome.freeAccess.benefits.networking.title")}</h3>
            <p>{tr("registerHome.freeAccess.benefits.networking.description")}</p>
          </div>
        </article>
      </div>
    </div>

    <div class="access-side">

      <!-- sección de acceso al evento -->
      <aside class="pass-card">
        <div class="event-info">
          <div class="event-info-item">
            <span>{tr("registerHome.eventInfo.venueLabel")}</span>
            <strong>{tr("registerHome.eventInfo.venue")}</strong>
          </div>
          <div class="event-info-item">
            <span>{tr("registerHome.eventInfo.dateLabel")}</span>
            <strong>{tr("registerHome.eventInfo.date")}</strong>
          </div>
          <div class="event-info-item">
            <span>{tr("registerHome.eventInfo.scheduleLabel")}</span>
            <strong>{tr("registerHome.eventInfo.schedule")}</strong>
          </div>
        </div>

        <a class="register-button uppercase text-xl" href={`${base}/registro-nuevo`}>
          {locale === 'es' ? 'Regístrate gratis' : 'Register for free'}
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <p class="pass-note">{locale === 'es' ? 'Confirmación inmediata vía correo electrónico.' : 'Immediate confirmation via email.'}</p>
      </aside>

      <!-- sección de aviso B2B -->
      <aside class="b2b-notice" aria-label="Evento exclusivo B2B">
        <div class="flex flex-row gap-x-2   " >
          <span class="notice-icon" aria-hidden="true">!</span>
          <h3 class="uppercase">{locale === 'es' ? 'Evento exclusivo B2B' : 'Exclusive B2B Event'}</h3>
        </div>
        <div>
          <p set:html={tr('registerHome.warningMessage')}/>
        </div>
      </aside>

    </div>
  </div>
</section>

<style>
  .free-access-shell {
    width: min(100%, 1116px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 424px;
    gap: 36px;
    align-items: start;
  }

  .benefits-card,
  .pass-card,
  .b2b-notice {
    border: 1px solid rgba(148, 163, 184, 0.34);
    border-radius: 16px;
    background: #ffffff;
    box-shadow: 0 22px 48px rgba(15, 23, 42, 0.08);
  }

  .benefits-card {
    padding: 40px 36px 34px;
  }

  .benefits-title {
    margin: 0 0 30px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #172033;
    font-size: clamp(1.1rem, 2.6vw, 1.7rem);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .title-icon {
    width: 27px;
    height: 27px;
    flex: 0 0 27px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: #061420;
    background: #27c9e8;
  }

  .title-icon svg {
    width: 18px;
    height: 18px;
  }

  .benefits-list {
    display: grid;
    gap: 24px;
  }

  .benefit-item {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 14px;
    align-items: start;
  }

  .benefit-icon {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: 8px;
  }

  .benefit-icon svg {
    width: 22px;
    height: 22px;
  }

  .benefit-icon.cyan {
    color: #28c8e7;
    background: rgba(40, 200, 231, 0.22);
  }

  .benefit-icon.purple {
    color: #b785ff;
    background: rgba(124, 82, 201, 0.34);
  }

  .benefit-icon.green {
    color: #4ad6a5;
    background: rgba(31, 138, 116, 0.34);
  }

  .benefit-icon.amber {
    color: #ffc21f;
    background: rgba(151, 112, 31, 0.34);
  }

  .benefit-item h3 {
    margin: 0 0 4px;
    color: #253047;
    font-size: 1.02rem;
    font-weight: 800;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .benefit-item p {
    margin: 0;
    color: #667085;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.45;
    letter-spacing: 0;
  }

  .access-side {
    display: grid;
    gap: 28px;
  }

  .pass-card {
    min-height: 267px;
    padding: 40px 36px 34px;
    text-align: center;
  }

  .event-info {
    display: grid;
    gap: 10px;
    margin-bottom: 24px;
    text-align: left;
  }

  .event-info-item {
    display: grid;
    gap: 3px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.22);
    padding-bottom: 10px;
  }

  .event-info-item span {
    color: #64748b;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .event-info-item strong {
    color: #172033;
    font-size: 0.95rem;
    font-weight: 900;
    line-height: 1.25;
  }

  .pass-kicker {
    margin: 0 0 12px;
    color: #64748b;
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .pass-price {
    margin: 0 0 28px;
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0;
  }

  .pass-price span {
    color: #172033;
    font-size: 2.05rem;
    font-weight: 900;
  }

  .register-button {
    width: 100%;
    min-height: 63px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    border-radius: 10px;
    background: linear-gradient(100deg, #18b9cf 0%, #2f6df0 100%);
    color: #ffffff;
    font-size: 1rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 16px 28px rgba(24, 185, 207, 0.22);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .register-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 34px rgba(47, 109, 240, 0.26);
  }

  .register-button svg {
    width: 21px;
    height: 21px;
  }

  .pass-note {
    margin: 15px 0 0;
    color: #778498;
    font-size: 0.78rem;
    font-weight: 500;
  }

  .b2b-notice {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 15px 18px;
    border-color: rgba(255, 182, 33, 0.48);
    background: #222222;
  }

  .notice-icon {
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: #ffc033;
    color: #232323;
    font-size: 0.85rem;
    font-weight: 900;
    line-height: 1;
  }

  .b2b-notice h3 {
    margin: 0 0 7px;
    color: #ffc400;
    font-size: 0.98rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .b2b-notice p {
    margin: 0;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.55;
    letter-spacing: 0;
  }

  .b2b-notice strong {
    font-weight: 900;
  }

  @media (max-width: 980px) {
    .free-access-shell {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .access-side {
      display: contents;
    }

    .pass-card {
      order: -1;
    }

    .benefits-card {
      order: 0;
    }

    .b2b-notice {
      order: 1;
    }
  }

  @media (max-width: 640px) {
    .benefits-card,
    .pass-card {
      border-radius: 14px;
      padding: 26px 20px;
    }

    .benefits-title {
      align-items: flex-start;
      font-size: 1.10rem;
      margin-bottom: 24px;
    }

    .benefit-item {
      grid-template-columns: 40px minmax(0, 1fr);
      gap: 12px;
    }

    .benefit-item h3 {
      font-size: 0.88rem;
      line-height: 1.3;
    }

    .benefit-item p {
      font-size: 0.8rem;
      line-height: 1.4;
    }

    .benefit-icon {
      width: 30px;
      height: 30px;
    }

    .pass-card {
      min-height: auto;
    }

    .b2b-notice {
      display: flex;
      flex-direction: column;
      padding: 18px 16px;
    }
  }
</style>
