---
import { useTranslations, getTranslation } from "../../utils/translations";
import { Redirect } from "../shared/Redirect";
import { DonwloadAccess } from "./DonwloadAccess";

const { locale, translations } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);
---

<section class="relative flex min-h-screen w-full items-center justify-center overflow-hidden px-4 py-20 text-white sm:px-6 lg:px-8">
  <div
    aria-hidden="true"
    class='absolute inset-0 bg-[url("/img/bg_itm_2026_2.webp")] bg-center bg-no-repeat'
  >
  </div>
  <div aria-hidden="true" class="absolute inset-0 bg-[#101820]/10"></div>
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 h-1/2 bg-linear-to-t from-black/60 to-transparent"
  >
  </div>

  <Redirect client:only="react" homePath={locale === "en" ? "/en/" : "/"} />

  <div class="relative z-10 mx-auto grid w-full max-w-6xl items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="text-center lg:text-left">
      <img
        src="/img/smarttecexpo_logo.svg"
        alt="Smart Technology Expo"
        class="mx-auto mb-8 h-auto w-56 sm:w-64 lg:mx-0"
        loading="eager"
      />
      <span class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-white/90">
        <span class="h-2 w-2 rounded-full bg-[#27c46a]"></span>
        {tr("thanks_page.eyebrow")}
      </span>
      <h1 class="mt-6 text-2xl font-black leading-tight sm:text-4xl lg:text-6xl">
        {tr("thanks_page.title")}
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-white/85 lg:mx-0">
        {tr("thanks_page.description")}
      </p>
    </div>

    <div class="rounded-[8px] border border-white/20 bg-white/12 p-6 shadow-2xl shadow-black/30 backdrop-blur-md sm:p-8">
      <!-- <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
        <div class="mx-auto flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-[#27c46a] text-white shadow-lg shadow-black/25 sm:mx-0">
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="h-9 w-9 fill-none stroke-current stroke-[2.5]"
          >
            <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </div>
        <div class="text-center sm:text-left">
          <h2 class="text-xl sm:text-2xl font-extrabold text-white">
            {tr("thanks_page.access_title")}
          </h2>
          <p class="mt-3 text-base leading-7 text-white/80">
            {tr("thanks_page.access_description")}
          </p>
          <p class="mt-4 border-l-0 border-white/30 bg-black/20 px-4 py-3 text-sm font-semibold text-white/85 sm:border-l-4">
            {tr("thanks_page.email_note")}
          </p>
        </div>
      </div> -->

      <div class="mt-2 flex flex-col justify-center md:justify-start items-start gap-5">
        <h2 class="text-xl sm:text-2xl font-extrabold text-white">
            {tr("thanks_page.access_title")}
        </h2>
        <DonwloadAccess client:only="react" text={tr("thanks_page.download_pass")} />
      </div>

      <div class="mt-8 border-t border-white/15 pt-6 text-center sm:text-left">
        <span class="text-sm font-bold uppercase tracking-[0.16em] text-white/70">
          {tr("thanks_page.social")}
        </span>
        <div class="mt-4 flex items-center justify-center gap-5 sm:justify-start">
          <a
            href="https://www.facebook.com/smarttechnologyexpo"
            target="_blank"
            rel="noreferrer"
            class="text-white/85 transition hover:scale-110 hover:text-[#dc2626]"
            aria-label="Facebook"
          >
            <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 fill-current">
              <path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/company/industrial-transformation-mexico/"
            target="_blank"
            rel="noreferrer"
            class="text-white/85 transition hover:scale-110 hover:text-[#dc2626]"
            aria-label="LinkedIn"
          >
            <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 fill-current">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/smart_technology_expo/"
            target="_blank"
            rel="noreferrer"
            class="text-white/85 transition hover:scale-110 hover:text-[#dc2626]"
            aria-label="Instagram"
          >
            <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 fill-current">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
