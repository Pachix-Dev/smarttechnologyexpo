---
import { useTranslations, getTranslation } from "../../utils/translations";
import LogoGrid from "../shared/LogoGrid.astro";
import FreeAccessSection from "./FreeAccessSection.astro";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);

// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);

import { mediaPlanito, strategicPartners } from "../../logos.js";

const base = locale === "en" ? "/en" : "";
---

<section class="w-full min-h-screen flex flex-col items-center justify-start">
  <header
    class="text-center bg-[url(/img/registerPage/hero_register_bg.png)] w-full h-auto sm:h-[200px] bg-cover bg-center flex flex-col sm:flex-row items-center justify-center text-2xl font-semibold text-white gap-x-36 gap-y-4 p-4"
  >
    <div>
      <a href={`${base}/`} >
        <img
          src="/img/smarttecexpo_logo.svg"
          alt="smart technology expo 2026"
          class="w-[150px] sm:w-[300px]"
        />
      </a>
    </div>
    <div>
      <h2
        class="text-2xl sm:text-5xl text-center sm:text-start font-montserrat-extra-bold-italic"
      >
        {locale === "es" ? "FORMA PARTE DE" : "BE PART OF"} <br /> {locale === "es" ? "LA COMUNIDAD" : "THE COMMUNITY"}
      </h2>
    </div>
  </header>

  <!-- sección de acceso gratuito -->
  <FreeAccessSection />

  <!-- patrocinadores -->
  <!-- <div class="w-full">
    <LogoGrid
      title={locale === "es" ? "PATROCINADORES" : "SPONSORS"}
      logos={strategicPartners}
      imageHeight="56px"
      columnsMin="100px"
      compact
    />
  </div> -->

</section>
