---
import { useTranslations, getTranslation } from "../../utils/translations";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);
// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);
---
<section class="pb-10 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-4xl font-extrabold text-center text-red-700 tracking-tight uppercase drop-shadow">{tr("rates.title")}</h2>
    <p class="text-center mb-12 text-gray-600 text-base sm:text-2xl">{tr("rates.description")}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      {/* RAW SPACE */}
      <div class="relative flex flex-col border-2 border-red-600 rounded-2xl bg-white shadow-xl overflow-hidden hover:scale-105 transition-transform">
        <div class="p-7 flex flex-col h-full">
          <h3 class="text-2xl font-extrabold text-red-700 uppercase tracking-wide mb-2">{locale === "es" ? "Espacio Libre" : "Raw Space"}</h3>
          <span class="inline-block bg-red-100 text-red-700 text-xs font-semibold px-2 py-1 rounded mb-2">{locale === "es" ? "Precio regular" : "Regular Price"}</span>
          <p class="text-3xl font-extrabold text-gray-900 mb-1">430<span class="text-xl font-bold align-top">USD</span></p>
          <p class="text-sm text-gray-600 mb-2">{locale === "es" ? "por m² + IVA" : "per sqm + VAT"}</p>
          <div class="mb-4">
            <h4 class="text-base font-semibold text-gray-800 mb-2">{locale === "es" ? "Incluye:" : "Includes:"}</h4>
            <ul class="space-y-2 text-gray-700 text-sm">
              <li class="flex items-start">
                  <p class="font-bold text-sm">{tr("rates.stand01.item01")}<br><span class="font-normal text-gray-500">{tr("rates.stand01.desc_item01")}</span>
                  </p>
              </li>
              <li class="flex items-start">
                  <p class="font-bold text-sm">{tr("rates.stand01.item02")}<br><span class="font-normal text-gray-500">{tr("rates.stand01.desc_item02")}</span>
                  </p>
              </li>
              <li class="flex items-start">
                  <p class="font-bold text-sm">{tr("rates.stand01.item03")}<br><span class="font-normal text-gray-500">{tr("rates.stand01.desc_item03")}</span>
                  </p>
              </li>
              <li class="flex items-start">
                  <p class="font-bold text-sm">{tr("rates.stand01.item04")}<br><span class="font-normal text-gray-500">{tr("rates.stand01.desc_item04")}</span>
                  </p>
              </li>
              <li class="flex items-start">
                  <p class="text-red-700 font-semibold">{tr("rates.stand01.not_include")}</p>
              </li>
            </ul>
          </div>
          <div class="flex flex-col items-center mb-6">
          <img src={`/img/raw_space_redner.png`} alt={locale === "es" ? "Stand Básico" : "Basic Stand"} class="w-[190px] sm:w-[250px] h-auto rounded-lg shadow-md border border-gray-100"/>
        </div>
        </div>
      </div>

      {/* EQUIPADO BÁSICO */}
      <div class="relative flex flex-col border-2 border-red-600 rounded-2xl bg-white shadow-xl overflow-hidden hover:scale-105 transition-transform">
        <div class="p-7 flex flex-col h-full">
          <h3 class="text-2xl font-extrabold text-red-700 uppercase tracking-wide mb-2">{locale === "es" ? "Stand Equipado" : "Equipped Booth"}</h3>
          <span class="inline-block bg-red-100 text-red-700 text-xs font-semibold px-2 py-1 rounded mb-2">{locale === "es" ? "Precio regular" : "Regular Price"}</span>
          <p class="text-3xl font-extrabold text-gray-900 mb-1">500 <span class="text-xl font-bold align-top">USD</span></p>
          <p class="text-sm text-gray-600 mb-2">{locale === "es" ? "por m² + IVA" : "per sqm + VAT"}</p>
          <div class="mb-4">
            <h4 class="text-base font-semibold text-gray-800 mb-2">{locale === "es" ? "Incluye:" : "Includes:"}</h4>
            <ul class="space-y-2 text-gray-700 text-sm">
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand02.item01")}<br> <span class="font-normal text-gray-500">{tr("rates.stand02.desc_item01")}</span></p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand02.item02")}<br> <span class="font-normal text-gray-500">{tr("rates.stand02.desc_item02")}</span></p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand02.item03")}<br> <span class="font-normal text-gray-500">{tr("rates.stand02.desc_item03")}</span></p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand02.item04")}<br> <span class="font-normal text-gray-500">{tr("rates.stand02.desc_item04")}</span></p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand02.item05")}<br> <span class="font-normal text-gray-500">{tr("rates.stand02.desc_item05")}</span></p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand02.item06")}<br> <span class="font-normal text-gray-500">{tr("rates.stand02.desc_item06")}</span></p>
              </li>
            </ul>
          </div>
        </div>
        <div class="flex flex-col items-center mb-6">
          <img src={`/img/stand_basico.webp`} alt={locale === "es" ? "Stand Básico" : "Basic Stand"} class="w-[190px] sm:w-[250px] h-auto rounded-lg shadow-md border border-gray-100"/>
        </div>
      </div>

      <!-- CONFORT PLUS -->
      <div class="relative flex flex-col border-2 border-red-600 rounded-2xl bg-white shadow-xl overflow-hidden hover:scale-105 transition-transform">
        <div class="p-7 flex flex-col h-full">
          <h3 class="text-2xl font-extrabold text-red-700 uppercase tracking-wide mb-2">{locale === "es" ? "Confort Plus" : "Comfort Plus"}</h3>
          <span class="inline-block bg-red-100 text-red-700 text-xs font-semibold px-2 py-1 rounded mb-2">{locale === "es" ? "Precio regular" : "Regular Price"}</span>
          <p class="text-3xl font-extrabold text-gray-900 mb-1">5,865 <span class="text-xl font-bold align-top">USD</span></p>
          <p class="text-sm text-gray-600 mb-2">{locale === "es" ? "+ IVA por stand de 9m²" : "+ IVA per 9sqm booth"}</p>
          <div class="mb-4">
            <h4 class="text-base font-semibold text-gray-800 mb-2">{locale === "es" ? "Incluye:" : "Includes:"}</h4>
            <ul class="space-y-2 text-gray-700 text-sm">
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand03.item01")} <br> <span class="font-normal text-gray-500">{tr("rates.stand03.desc_item01")}</span> </p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand03.item02")} <br> <span class="font-normal text-gray-500">{tr("rates.stand03.desc_item02")}</span> </p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand03.item03")} <br> <span class="font-normal text-gray-500">{tr("rates.stand03.desc_item03")}</span> </p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand03.item04")} <br> <span class="font-normal text-gray-500">{tr("rates.stand03.desc_item04")}</span> </p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand03.item05")} <br> <span class="font-normal text-gray-500">{tr("rates.stand03.desc_item05")}</span> </p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand03.item06")} <br> <span class="font-normal text-gray-500">{tr("rates.stand03.desc_item06")}</span> </p>
              </li>
              <li class="flex items-start">
                <p class="font-bold text-sm">{tr("rates.stand03.item07")} <br> <span class="font-normal text-gray-500">{tr("rates.stand03.desc_item07")}</span> </p>
              </li>
            </ul>
          </div>
        </div>
        <div class="flex flex-col items-center mb-6">
          <img src={`/img/stand_confort.webp`} alt={locale === "es" ? "Stand Confort Plus" : "Comfort Plus Stand"} class="w-[190px] sm:w-[250px] h-auto rounded-lg shadow-md border border-gray-100"/>
        </div>
      </div>
    </div>
    
  </div>
</section>