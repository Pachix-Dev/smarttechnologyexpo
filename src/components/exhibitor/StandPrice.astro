---
import { useTranslations, getTranslation } from "../../utils/translations";

const { locale, translations } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);

const base = locale === "es" ? "" : "/en";
const regularPriceLabel = locale === "es" ? "Precio regular" : "Regular price";
const includesLabel = locale === "es" ? "Incluye" : "Includes";
const ctaLabel = locale === "es" ? "Cotizar espacio" : "Request quote";

const plans = [
  {
    key: "stand01",
    name: locale === "es" ? "Espacio Libre" : "Raw Space",
    price: "430",
    unit: locale === "es" ? "por m\u00b2 + IVA" : "per sqm + VAT",
    image: "/img/raw_space_redner.png",
    imageAlt: locale === "es" ? "Render de espacio libre" : "Raw space render",
    items: ["item01", "item02", "item03", "item04"],
    note: "not_include",
  },
  {
    key: "stand02",
    name: locale === "es" ? "Stand Equipado" : "Equipped Booth",
    price: "500",
    unit: locale === "es" ? "por m\u00b2 + IVA" : "per sqm + VAT",
    image: "/img/stand_basico.webp",
    imageAlt: locale === "es" ? "Stand equipado" : "Equipped booth",
    items: ["item01", "item02", "item03", "item04", "item05", "item06"],
  },
  {
    key: "stand03",
    name: locale === "es" ? "Confort Plus" : "Comfort Plus",
    price: "5,865",
    unit: locale === "es" ? "+ IVA por stand de 9 m\u00b2" : "+ VAT per 9 sqm booth",
    image: "/img/stand_confort.webp",
    imageAlt: locale === "es" ? "Stand Confort Plus" : "Comfort Plus stand",
    items: ["item01", "item02", "item03", "item04", "item05", "item06", "item07"],
    featured: true,
  },
];
---

<section class="bg-white px-4 py-14 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto mb-10 max-w-3xl text-center sm:mb-12">
      <h2
        class="text-balance text-3xl font-black tracking-normal text-[#1d1d1b] uppercase sm:text-4xl lg:text-5xl"
      >
        {tr("rates.title")}
      </h2>
      <p class="mt-4 text-base leading-7 text-gray-600 sm:text-lg">
        {tr("rates.description")}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {
        plans.map((plan) => (
          <article
            class:list={[
              "group relative flex h-full min-h-[640px] flex-col overflow-hidden rounded-[8px] border bg-white shadow-[0_18px_45px_rgba(15,23,42,0.10)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(15,23,42,0.16)]",
              plan.featured
                ? "border-[#ed001b] md:col-span-2 lg:col-span-1"
                : "border-gray-200",
            ]}
          >
            <div
              class:list={[
                "h-2 w-full",
                plan.featured ? "bg-[#ed001b]" : "bg-[#1d1d1b]",
              ]}
            />

            <div class="flex flex-1 flex-col p-5 sm:p-6 lg:p-7">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-extrabold tracking-[0.18em] text-[#ed001b] uppercase">
                    {regularPriceLabel}
                  </p>
                  <h3 class="mt-2 text-2xl leading-tight font-black tracking-normal text-[#1d1d1b] uppercase">
                    {plan.name}
                  </h3>
                </div>

                <span
                  class:list={[
                    "inline-flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-black",
                    plan.featured
                      ? "bg-[#ed001b] text-white"
                      : "bg-gray-100 text-[#1d1d1b]",
                  ]}
                  aria-hidden="true"
                >
                  {plan.featured ? "+" : "$"}
                </span>
              </div>

              <div class="mt-6 border-y border-gray-100 py-5">
                <p class="flex items-start gap-2 text-[#1d1d1b]">
                  <span class="text-4xl leading-none font-black sm:text-5xl">
                    {plan.price}
                  </span>
                  <span class="pt-1 text-lg font-extrabold">USD</span>
                </p>
                <p class="mt-2 text-sm leading-6 font-medium text-gray-500">
                  {plan.unit}
                </p>
              </div>

              <div class="mt-5 flex-1">
                <h4 class="text-sm font-black tracking-[0.14em] text-[#1d1d1b] uppercase">
                  {includesLabel}
                </h4>
                <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-700">
                  {plan.items.map((itemKey) => {
                    const item = tr(`rates.${plan.key}.${itemKey}`);
                    const description = tr(
                      `rates.${plan.key}.desc_${itemKey}`,
                      ""
                    );

                    return (
                      <li class="flex gap-3">
                        <svg
                          class="mt-1 size-4 shrink-0 text-[#ed001b]"
                          viewBox="0 0 20 20"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.1 7.16a1 1 0 0 1-1.42 0L4.29 9.93a1 1 0 0 1 1.42-1.408l3.19 3.217 6.39-6.443a1 1 0 0 1 1.414-.006Z"
                            clip-rule="evenodd"
                          />
                        </svg>
                        <p>
                          <span class="font-extrabold text-[#1d1d1b]">
                            {item}
                          </span>
                          {description && (
                            <span class="block text-gray-500">
                              {description}
                            </span>
                          )}
                        </p>
                      </li>
                    );
                  })}
                </ul>

                {plan.note && (
                  <p class="mt-4 rounded-md bg-red-50 px-3 py-2 text-sm leading-6 font-semibold text-red-700">
                    {tr(`rates.${plan.key}.${plan.note}`)}
                  </p>
                )}
              </div>

              <div class="mt-6">
                <div class="flex aspect-[4/3] items-center justify-center overflow-hidden rounded-[8px] bg-gray-50 p-4 ring-1 ring-gray-100">
                  <img
                    src={plan.image}
                    alt={plan.imageAlt}
                    class="max-h-full w-full object-contain transition duration-300 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                </div>

                <a
                  href={`${base}/expositor-smarttechnologyexpo`}
                  class="mt-5 inline-flex h-12 w-full items-center justify-center rounded-full bg-[#1d1d1b] px-5 text-sm font-black tracking-[0.12em] text-white uppercase no-underline transition duration-200 hover:bg-[#ed001b] focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ed001b]"
                >
                  {ctaLabel}
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
