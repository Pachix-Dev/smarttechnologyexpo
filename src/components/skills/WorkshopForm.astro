---
// WorkshopForm.astro — Wrapper delgado del formulario de talleres.
// Lee las traducciones con tr() (desde tus locales), arma un objeto `labels`
// y monta la isla React WorkshopFormIsland, pasándole idioma y textos.
import WorkshopFormIsland from './WorkshopFormIsland.jsx';
import './workshopForm.css';
import { useTranslations, getTranslation } from '../../utils/translations';

export interface Props {
  accent?: string;
  registroHref?: string;
}

const { translations, locale } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = '') => getTranslation(translations, key, fallback);

const { accent = '#E2101A', registroHref = '/registro/' } = Astro.props;
const lang = locale === 'en' ? 'en' : 'es';

// Todos los textos del formulario, ya traducidos, para pasarlos a la isla.
const labels = {
  eyebrow: tr('skills.form.eyebrow', 'REGISTRO'),
  title: tr('skills.form.title', 'Inscríbete a un taller'),
  desc: tr('skills.form.desc', 'Los talleres tienen cupo limitado. Busca tu registro con tu correo y confirma tu lugar en segundos.'),
  notice_a: tr('skills.form.notice_a', 'Es indispensable contar con tu '),
  notice_b: tr('skills.form.notice_b', 'registro previo al evento general'),
  notice_c: tr('skills.form.notice_c', ' Smart Technology Expo 2026 para poder inscribirte a un taller.'),
  perk1: tr('skills.form.perk1', 'Confirmación inmediata de tu lugar por correo'),
  perk2: tr('skills.form.perk2', 'Material y prácticas incluidas en cada taller'),
  perk3: tr('skills.form.perk3', 'Constancia de participación Smart Technology Expo'),
  step1: tr('skills.form.step1', 'PASO 1'),
  step1_title: tr('skills.form.step1_title', 'Busca tu registro'),
  step1_sub: tr('skills.form.step1_sub', 'Ingresa el correo con el que te registraste al evento general; recuperaremos tus datos automáticamente.'),
  email: tr('skills.form.email', 'CORREO ELECTRÓNICO'),
  email_ph: tr('skills.form.email_ph', 'nombre@empresa.com'),
  lookup_err: tr('skills.form.lookup_err', 'No encontramos un registro con ese correo. Verifica que hayas completado tu registro general al evento antes de inscribirte a un taller.'),
  lookup_btn: tr('skills.form.lookup_btn', 'BUSCAR MI REGISTRO'),
  fine1_a: tr('skills.form.fine1_a', '¿Aún no tienes tu registro general? '),
  fine1_b: tr('skills.form.fine1_b', 'Complétalo primero en la página principal del evento.'),
  found: tr('skills.form.found', 'Datos recuperados de tu registro general.'),
  full_name: tr('skills.form.full_name', 'NOMBRE COMPLETO'),
  phone: tr('skills.form.phone', 'TELÉFONO'),
  company: tr('skills.form.company', 'EMPRESA'),
  position: tr('skills.form.position', 'PUESTO / CARGO'),
  select_ws: tr('skills.form.select_ws', 'SELECCIONA UN TALLER'),
  choose_ws: tr('skills.form.choose_ws', '— Elige un taller —'),
  select_err: tr('skills.form.select_err', 'Por favor selecciona un taller.'),
  submit: tr('skills.form.submit', 'CONFIRMAR INSCRIPCIÓN'),
  other_email: tr('skills.form.other_email', 'Buscar con otro correo'),
  fine2: tr('skills.form.fine2', 'Al enviar aceptas el aviso de privacidad de Smart Technology Expo.'),
  success_title: tr('skills.form.success_title', '¡Registro recibido!'),
  thanks: tr('skills.form.thanks', 'Gracias, '),
  sent_to: tr('skills.form.sent_to', '. Te enviamos la confirmación de tu lugar a '),
  another: tr('skills.form.another', 'REGISTRAR OTRO'),
};
---

<WorkshopFormIsland
  client:load
  lang={lang}
  labels={labels}
  accent={accent}
  registroHref={registroHref}
/>