---
export interface LogoItem {
  src: string
  alt: string
  width?: number
  height?: number
}

export interface Props {
  logos: LogoItem[]
}

const { logos = [] } = Astro.props
---

<section class="mx-auto w-full max-w-6xl">
  <div class="grid grid-cols-1 items-center justify-items-center gap-x-6 gap-y-8 min-[480px]:grid-cols-1 sm:grid-cols-1 lg:grid-cols-1 xl:grid-cols-1">
    {
      logos.map((logo) => (
        <div class="group flex min-h-20 w-full items-center justify-center overflow-hidden rounded-lg transition duration-300 hover:-translate-y-1 hover:drop-shadow-[0_12px_18px_rgba(0,0,0,0.14)] sm:min-h-24">
          <img
            class="block h-auto max-h-24 w-auto max-w-full object-contain p-2 transition duration-300 group-hover:scale-105 sm:max-h-32"
            src={logo.src}
            alt={logo.alt}
            width={logo.width}
            height={logo.height}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))
    }
  </div>
</section>
