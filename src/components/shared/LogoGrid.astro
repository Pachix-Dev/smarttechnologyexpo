---
export interface LogoItem {
  src: string
  alt: string
  href?: string
  width?: number
  height?: number
}

export interface Props {
  logos: LogoItem[]
  title?: string
  eyebrow?: string
  description?: string
  imageHeight?: string
  columnsMin?: string
  compact?: boolean
  "class"?: string
}

const {
  logos = [],
  title,
  eyebrow,
  description,
  imageHeight = "72px",
  columnsMin = "150px",
  compact = false,
  class: className = "",
} = Astro.props

const sectionStyle = `--logo-image-height: ${imageHeight}; --logo-grid-min: ${columnsMin};`
---

<section
  class:list={[
    "logo-grid-section",
    compact && "is-compact",
    className,
  ]}
  style={sectionStyle}
>
  {
    (eyebrow || title || description) && (
      <div class="logo-grid-header">
        {eyebrow && <p class="logo-grid-eyebrow">{eyebrow}</p>}
        {title && <h2 class="logo-grid-title">{title}</h2>}
        {description && <p class="logo-grid-description">{description}</p>}
      </div>
    )
  }

  <div class="logo-grid" aria-label={title ?? "Logo grid"}>
    {
      logos.map((logo) => (
        <div class="logo-grid-card">
          {logo.href ? (
            <a
              class="logo-grid-media"
              href={logo.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={logo.alt}
            >
              <img
                class="logo-grid-image"
                src={logo.src}
                alt={logo.alt}
                width={logo.width}
                height={logo.height}
                loading="lazy"
                decoding="async"
              />
            </a>
          ) : (
            <div class="logo-grid-media">
              <img
                class="logo-grid-image"
                src={logo.src}
                alt={logo.alt}
                width={logo.width}
                height={logo.height}
                loading="lazy"
                decoding="async"
              />
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>

<style>
  .logo-grid-section {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 3rem 1rem;
    color: #171717;
  }

  .logo-grid-section.is-compact {
    padding-block: 1.75rem;
  }

  .logo-grid-header {
    max-width: 760px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .logo-grid-eyebrow {
    margin: 0 0 0.45rem;
    color: #ed332d;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .logo-grid-title {
    margin: 0;
    color: #141414;
    font-size: clamp(1.85rem, 4vw, 2.75rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .logo-grid-description {
    max-width: 620px;
    margin: 0.85rem auto 0;
    color: #626262;
    font-size: 0.98rem;
    line-height: 1.65;
  }

  .logo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, var(--logo-grid-min)), 1fr));
    gap: 0.9rem;
    align-items: stretch;
  }

  .logo-grid-card {
    position: relative;
    min-height: 118px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid #e9e9e9;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 14px 30px rgba(17, 24, 39, 0.06);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .logo-grid-card:hover {
    transform: translateY(-3px);
    border-color: #d7d7d7;
    box-shadow: 0 18px 36px rgba(17, 24, 39, 0.1);
  }

  .logo-grid-media {
    width: 100%;
    min-height: 118px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.35rem;
    text-decoration: none;
  }

  .logo-grid-image {
    display: block;
    width: auto;
    max-width: 82%;
    max-height: var(--logo-image-height);
    object-fit: contain;
    transition:
      filter 0.2s ease,
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .logo-grid-card:hover .logo-grid-image {
    opacity: 1;
    transform: scale(1.02);
  }

  @media (max-width: 640px) {
    .logo-grid-section {
      padding: 2.25rem 1rem;
    }

    .logo-grid-card,
    .logo-grid-media {
      min-height: 96px;
    }

    .logo-grid-media {
      padding: 1rem;
    }
  }
</style>
