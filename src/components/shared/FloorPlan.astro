---
import { useTranslations, getTranslation } from "../../utils/translations";

const { locale, translations } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);

const floorPlanFile = "/files/PLANO_STE_2026_22_07_2026.pdf";
const floorPlanTitle = tr(
  "floorPlan.title",
  locale === "en" ? "Floor plan" : "Plano del evento"
);
const floorPlanDescription =  locale === "en"
    ? "Review the current exhibitor floor plan, download it or open it in a new tab."
    : "Consulta el plano actual de expositores, descargalo o abrelo en una nueva pestana."
---

<section
  class="min-h-screen bg-[#080808] bg-[linear-gradient(180deg,rgba(0,0,0,0.78),rgba(0,0,0,0.94))] px-[14px] pb-11 pt-16 font-['Archivo',Helvetica,Arial,sans-serif] text-white md:px-5 md:pb-16"
>
  <div class="mx-auto w-full max-w-[1180px]">
    <div class="mb-[22px] max-w-[760px] md:mb-7">
      <p class="mb-3 text-[13px] font-extrabold uppercase tracking-normal text-[#E2101A]">
        Smart Technology Expo 2026
      </p>
      <h1 class="m-0 text-[34px] font-black leading-[0.96] md:text-[64px]">
        {floorPlanTitle}
      </h1>
      <p class="mt-[18px] max-w-[720px] text-[17px] leading-[1.7] text-[#c8c8c8]">
        {floorPlanDescription}
      </p>
    </div>

    <div
      class="mb-[22px] gap-3 flex md:flex-wrap"
      aria-label={locale === "en" ? "Floor plan actions" : "Acciones del plano"}
    >
      <a
        class="inline-flex min-h-11 w-full items-center justify-center gap-[9px] rounded-md border border-[#e2101a] bg-[#e2101a] px-[18px] py-3 text-sm font-extrabold text-white no-underline transition duration-200 hover:-translate-y-px hover:border-[#e2101a] hover:bg-[#b80d15] md:w-auto"
        href={floorPlanFile}
        target="_blank"
        rel="noopener noreferrer"
      >
        {tr("floorPlan.open", locale === "en" ? "Open in new tab" : "Abrir en otra pagina")}
        <svg
          class="h-[17px] w-[17px] flex-none"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path fill="currentColor" d="m16.172 11-5.364-5.364 1.414-1.414L20 12l-7.778 7.778-1.414-1.414L16.172 13H4v-2z"></path>
        </svg>
      </a>
      <a
        class="inline-flex min-h-11 w-full items-center justify-center gap-[9px] rounded-md border border-[#333] bg-[#141414] px-[18px] py-3 text-sm font-extrabold text-white no-underline transition duration-200 hover:-translate-y-px hover:border-[#e2101a] md:w-auto"
        href={floorPlanFile}
        download
      >
        {tr("floorPlan.download", locale === "en" ? "Download PDF" : "Descargar PDF")}
        <svg
          class="h-[17px] w-[17px] flex-none"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path fill="currentColor" d="M19 9h-4V3H9v6H5l7 7zM5 18v2h14v-2z"></path>
        </svg>
      </a>
    </div>

    <div class="overflow-hidden rounded-lg border border-[#2d2d2d] bg-[#121212]">
      <object
        class="block h-[68vh] min-h-[560px] w-full bg-white md:h-[72vh] md:min-h-[620px]"
        data={`${floorPlanFile}#toolbar=1&navpanes=0&view=FitH`}
        type="application/pdf"
        title={floorPlanTitle}
      >
        <div class="flex min-h-[560px] flex-col items-center justify-center gap-3 p-6 text-center md:min-h-[620px]">
          <p class="m-0 max-w-[420px] leading-relaxed text-[#c8c8c8]">
          {
            tr(
              "floorPlan.fallback",
              locale === "en"
                ? "If the PDF preview does not load, open it in a new tab."
                : "Si la vista previa del PDF no carga, abrelo en una nueva pestana."
            )
          }
          </p>
          <a
            class="font-extrabold text-[#ff3c3c]"
            href={floorPlanFile}
            target="_blank"
            rel="noopener noreferrer"
          >
            {tr("floorPlan.openFallback", locale === "en" ? "Open floor plan" : "Abrir plano")}
          </a>
        </div>
      </object>
    </div>
  </div>
</section>
