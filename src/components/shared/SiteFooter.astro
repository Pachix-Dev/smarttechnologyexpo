---
// SiteFooter.astro — shared footer for both interiors.

export interface Props {
  text?: string;
  note?: string;
}

const {
  text = 'SMART TECHNOLOGY EXPO · CON26 — PROGRAMA EDUCATIVO 2026',
  note = 'Programa preliminar · sujeto a cambios',
} = Astro.props;
---

<footer class="sf-footer">
  <div class="sf-inner">
    <div class="sf-text">{text}</div>
    <div class="sf-note">{note}</div>
  </div>
</footer>

<style>
  .sf-footer {
    background: #000;
    border-top: 1px solid #161616;
    font-family: 'Archivo', Helvetica, Arial, sans-serif;
  }

  .sf-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 36px clamp(16px, 4vw, 40px);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .sf-text {
    font-size: 11px;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: #666;
  }

  .sf-note {
    font-size: 12px;
    color: #555;
  }
</style>
