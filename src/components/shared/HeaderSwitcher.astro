---
// HeaderSwitcher.astro — shared sticky header with Conferencias/Talleres tab switcher.
// Usage: <HeaderSwitcher active="conferencias" /> or active="talleres"
// Links assume /conferencias and /talleres routes — adjust hrefs to your routing.

import { useTranslations, getTranslation } from "../../utils/translations";

export interface Props {
  active?: 'conferencias' | 'talleres';
  navbarOffset?: number;
}

const { active = 'conferencias', navbarOffset = 80 } = Astro.props;
const isConf = active === 'conferencias';
const isSkills = active === 'talleres';
const { translations, locale } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = "") => getTranslation(translations, key, fallback);
const base = locale === 'en' ? '/en' : '';
---

<header class="hs-header" style={`top:${navbarOffset}px`}>
  <div class="hs-inner">
    <div class="hs-tabs">
      <a href={`${base}/insights`} class={isConf ? 'hs-tab hs-tab--active' : 'hs-tab'}>{tr("programSwitch.conferences", "CONFERENCIAS")}</a>
      <a href={`${base}/skills`} class={isSkills ? 'hs-tab hs-tab--active' : 'hs-tab'}>{tr("programSwitch.workshops", "TALLERES")}</a>
    </div>
  </div>
</header>

<style>
  .hs-header {
    position: sticky;
    top: 0; /* overridden inline via navbarOffset prop */
    z-index: 40; /* keep below your main navbar (typically z-index 50+) */
    background: #000;
    border-bottom: 1px solid rgba(0, 0, 0, 0.4);
    font-family: 'Archivo', Helvetica, Arial, sans-serif;
  }

  .hs-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
    height: 71px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .hs-tabs {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(0, 0, 0, 0.32);
    padding: 4px;
    border-radius: 3px;
    flex: none;
  }

  .hs-tab {
    padding: 9px 18px;
    background: transparent;
    color: rgba(255, 255, 255, 0.78);
    border: none;
    border-radius: 2px;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.1em;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .hs-tab--active {
    background: #fff;
    color: #000;
    font-weight: 800;
  }
</style>