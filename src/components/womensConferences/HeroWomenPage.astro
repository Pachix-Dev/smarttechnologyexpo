---
import { useTranslations, getTranslation } from "../../utils/translations";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);
// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);
---

<section
  class="relative flex min-h-[620px] w-full items-center justify-center overflow-hidden bg-[#d70a58] bg-[url('/img/bg_mujeres_hero.webp')] bg-cover bg-[center_left_42%] px-5 py-16 text-white sm:min-h-[620px] sm:bg-center sm:px-8 md:py-20 lg:min-h-[660px] lg:px-12"
>
  <div class="absolute inset-0 bg-[#e0005a]/20" aria-hidden="true"></div>

  <div
    class="relative z-10 mx-auto grid w-full max-w-[1180px] items-center gap-8 md:grid-cols-[46fr_54fr] md:gap-24 lg:grid-cols-[48fr_52fr]"
    data-aos="fade-in"
    data-aos-duration="700"
  >
    <div
      class="flex justify-center md:justify-start"
      data-aos="zoom-in-right"
      data-aos-duration="900"
      data-aos-delay="150"
    >
      <img
        src="/img/mujeres_logo.webp"
        alt={tr("women.hero.logo_alt", "Logo de Mujeres")}
        class="h-auto w-full"
      />
    </div>

    <div
      class="text-center uppercase md:text-left"
      data-aos="fade-left"
      data-aos-duration="900"
      data-aos-delay="300"
    >
      <p
        class="m-0 text-[clamp(3.8rem,18vw,6.6rem)] font-black leading-[0.86] tracking-normal sm:text-[clamp(5rem,10vw,8.2rem)] md:text-[clamp(5rem,9vw,8.5rem)]"
      >
        {locale === "es" ? "19 NOV" : "NOV 19"}
      </p>
      <p
        class="m-0 mt-3 text-[clamp(1.65rem,7vw,2.8rem)] font-black leading-none tracking-normal sm:text-[clamp(2.2rem,4.2vw,3.5rem)]"
      >
        {locale === "es" ? "Salón de Eventos" : "Event Hall"}
      </p>
      <p
        class="m-0 mt-1 text-[clamp(1.25rem,5.5vw,2rem)] font-light leading-none tracking-normal sm:text-[clamp(1.7rem,3.2vw,2.75rem)]"
      >
        Expo Guadalajara
      </p>
    </div>
  </div>
</section>
