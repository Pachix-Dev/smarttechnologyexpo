---
// src/components/drone-innovators/DroneHero.astro
import { useTranslations, getTranslation } from '../../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations(Astro.props, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)

const dateBadge = locale === 'en'
  ? '/img/drone-innovators/date_en-hero.webp'
  : '/img/drone-innovators/date_es-hero.webp'
---

<section class="dh-hero">

  <img
    src="/img/drone-innovators/bg-hero.webp"
    alt=""
    class="dh-bg"
    aria-hidden="true"
  />

  <div class="dh-inner">

    <div class="dh-left" data-aos="fade-right" data-aos-duration="900">
      <img
        src="/img/drone-innovators/logo-hero.webp"
        alt="Drone Innovators Forum MX"
        class="dh-logo"
      />
    </div>

    <div class="dh-right" data-aos="fade-left" data-aos-duration="900" data-aos-delay="200">
      <img
        src={dateBadge}
        alt={locale === 'en'
          ? 'November 18–20, 2026 · Expo Guadalajara'
          : '18–20 Noviembre 2026 · Expo Guadalajara'}
        class="dh-date"
      />
    </div>

  </div>

</section>

<style>
  .dh-hero {
    position: relative;
    width: 100%;
    background: #0b1627;
    max-height: 680px;
    overflow: hidden;
  }

  .dh-bg {
    display: block;
    width: 100%;
    height: 680px;
    object-fit: cover;
    object-position: center bottom;
  }

  .dh-inner {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }

  .dh-left {
    position: absolute;
    top: 27%;
    left: 6.3%;
  }

  .dh-logo {
    width: 49vw;
    min-width: 200px;
    height: auto;
    display: block;
  }

  .dh-right {
    position: absolute;
    top: 23%;
    right: 5%;
  }

  .dh-date {
    width: 33.5vw;
    min-width: 160px;
    height: auto;
    display: block;
  }

  /* ── DESKTOP ≥1281px ── */
@media (min-width: 1281px) {
  .dh-hero  { max-height: 680px; }
  .dh-bg    { height: 680px; object-position: center bottom; }
  .dh-left  { top: 27%; left: 6.3%; }
  .dh-right { top: 23%; right: 5%; }
  .dh-logo  { width: 49vw; min-width: 200px; }
  .dh-date  { width: 33.5vw; min-width: 160px; }
}

  /* ── TABLET GRANDE 1024px–1280px ── */
  @media (max-width: 1280px) and (min-width: 1025px) {
    .dh-hero  { max-height: 580px; }
    .dh-bg    { height: 580px; object-position: center bottom; }
    .dh-left  { top: 32%; left: 0.8%; }
    .dh-right { top: 29%; right: 4%; }
    .dh-logo  { width: 56vw; min-width: 200px; }
    .dh-date  { width: 35vw; min-width: 160px; }
  }

  /* ── TABLET 769px–1024px ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .dh-hero  { max-height: 460px; }
    .dh-bg    { height: 460px; object-position: center bottom; }
    .dh-left  { top: 30%; left: 6%; }
    .dh-right { top: 26%; right: 3%; }
    .dh-logo  { width: 50vw; min-width: 180px; }
    .dh-date  { width: 35vw; min-width: 150px; }
  }

  /* ── MOBILE ≤768px ── */
  @media (max-width: 768px) {
    .dh-hero  { max-height: 420px; }
    .dh-bg    { height: 420px; object-position: 30% bottom; }
    .dh-left  { top: 32%; left: 2%; transform: translateX(-50%); }
    .dh-right { top: 32%; left: 62%; transform: translateX(-50%); right: auto; }
    .dh-logo  { width: 58vw; min-width: 160px; }
    .dh-date  { width: 35vw; min-width: 140px; }
  }

  /* ── MOBILE PEQUEÑO ≤480px ── */
  @media (max-width: 480px) {
    .dh-hero  { max-height: 280px; }
    .dh-bg    { height: 280px; object-position: 30% bottom; }
    .dh-left  { top: 40%; left: 1%; transform: translateX(-50%); }
    .dh-right { top: 38%; left: 63%; transform: translateX(-50%); right: auto; }
    .dh-logo  { width: 60vw; min-width: 160px; }
    .dh-date  { width: 25vw; min-width: 140px; }
  }

  /* ── MOBILE MUY PEQUEÑO ≤380px ── */
  @media (max-width: 380px) {
    .dh-hero  { max-height: 240px; }
    .dh-bg    { height: 240px; object-position: 30% bottom; }
    .dh-left  { top: 41%; left: 1%; transform: translateX(-50%); }
    .dh-right { top: 42%; left: 65%; transform: translateX(-50%); right: auto; }
    .dh-logo  { width: 61vw; min-width: 140px; }
    .dh-date  { width: 30vw; min-width: 120px; }
  }
</style>