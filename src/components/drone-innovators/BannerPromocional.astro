---
// src/components/drone-innovators/BannerPromocional.astro
import { useTranslations, getTranslation } from '../../utils/translations'

export interface Props {
  locale?: string
}

const { locale, translations } = await useTranslations(Astro.props, Astro)
const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)
---

<section class="bp-section">

  <!-- Fondo -->
  <img
    src="/img/drone-innovators/bg-bannerpromocional.webp"
    alt=""
    class="bp-bg"
    aria-hidden="true"
  />

  <!-- Contenido centrado -->
  <div class="bp-inner" data-aos="fade-up" data-aos-duration="700">
    <p class="bp-pre">
      {tr('droneInnovators.banner.pre', 'NO PIERDAS')}
    </p>
    <h2 class="bp-title">
      {tr('droneInnovators.banner.title', 'LA OPORTUNIDAD')}
    </h2>
    <p class="bp-sub">
      {tr('droneInnovators.banner.sub', 'de ser parte del evento ...')}
    </p>
  </div>

</section>

<style>
  .bp-section {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #0b1627;
  }

  .bp-bg {
    display: block;
    width: 100%;
    height: auto;
  }

  .bp-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 2rem 15%;
    box-sizing: border-box;
  }

  .bp-pre {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.2rem, 3.8vw, 3.7rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.01em;
    margin: 0;
    line-height: 1.2;
    align-self: center;
  }

  .bp-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.5rem, 7vw, 6rem);
    font-weight: 1000;
    color: #fff;
    letter-spacing: 0em;
    margin: 0;
    line-height: 1;
    text-transform: uppercase;
    align-self: center;
  }

  .bp-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(0.85rem, 1.8vw, 1.8rem);
    font-weight: 500;
    color: #fafbfb;
    margin: 0.5rem 0 0;
    line-height: 0.5;
    margin-left: -2.2rem;
  }

  /* ── DESKTOP ≥1281px ── */
  @media (min-width: 1281px) {
    .bp-inner { padding: 2rem 15%; }
    .bp-pre   { font-size: 3.7rem; align-self: center; }
    .bp-title { font-size: 6rem; align-self: center; }
    .bp-sub   { font-size: 1.8rem; margin-left: -2.2rem; line-height: 0.5; }
  }

  /* ── TABLET GRANDE 1025px–1280px ── */
  @media (max-width: 1280px) and (min-width: 1025px) {
    .bp-inner { padding: 2rem 12%; }
    .bp-pre   { font-size: 3.2rem; align-self: center; }
    .bp-title { font-size: 5rem; align-self: center; }
    .bp-sub   { font-size: 1.5rem; margin-left: -2.2rem; line-height: 0.5; }
  }

  /* ── TABLET 769px–1024px ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .bp-inner { padding: 2rem 10%; }
    .bp-pre   { font-size: 2.6rem; align-self: center; }
    .bp-title { font-size: 4rem; align-self: center; }
    .bp-sub   { font-size: 1.2rem; margin-left: -2.2rem; line-height: 0.5; }
  }

  /* ── MOBILE ≤768px ── */
  @media (max-width: 768px) {
    .bp-inner { padding: 2rem 2rem; align-items: center; }
    .bp-pre   { font-size: 2rem; align-self: center; }
    .bp-title { font-size: 3rem; align-self: center; }
    .bp-sub   { font-size: 1rem; margin-left: 0; line-height: 1.4; align-self: center; }
  }

  /* ── MOBILE PEQUEÑO ≤480px ── */
  @media (max-width: 480px) {
    .bp-inner { padding: 1.5rem 1.25rem; align-items: center; }
    .bp-pre   { font-size: 1.5rem; align-self: center; }
    .bp-title { font-size: 2.1rem; align-self: center; }
    .bp-sub   { font-size: 0.85rem; margin-left: 0; line-height: 1.4; align-self: center; }
  }

  /* ── MOBILE MUY PEQUEÑO ≤380px ── */
  @media (max-width: 380px) {
    .bp-inner { padding: 1rem 1rem; align-items: center; }
    .bp-pre   { font-size: 1.2rem; align-self: center; }
    .bp-title { font-size: 1.8rem; align-self: center; }
    .bp-sub   { font-size: 0.75rem; margin-left: 0; line-height: 1.4; align-self: center; }
  }
</style>