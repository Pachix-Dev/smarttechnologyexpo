---
import { useTranslations, getTranslation } from "../../utils/translations";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);

// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);

const isSpanish = locale === "es";

const nationalAgents = [
  {
    name: "Paulina Padilla",
    region: "México",
    email: "paulina.padilla@igeco.mx",
    photo: "/img/team/paulinap.jpg",
    position: "Sales Manager",
  },
  {
    name: "Brandom Magaña",
    region: "México",
    email: "brandom.magana@igeco.mx",
    photo: "/img/team/brandom.jpg",
    position: "Sales Manager",
  },
  {
    name: "Sofía Manríquez",
    region: "México",
    email: "sofia.manriquez@igeco.mx",
    photo: "/img/team/sofia.jpg",
    position: "Sales Manager",
  },
];

const internationalAgents = [
  {
    name: "Claudia Rodríguez",
    region: "México, Canada, Centro & Sudamérica",
    email: "claudia.rodriguez@igeco.mx",
    photo: "/img/Claudia_Rodríguez.jpeg",
    position: "Executive Director of Tech & Automation Exhibitions",
  },
  {
    name: "Simone Robering",
    region: "Alemania, Europa, Medio Oriente y África",
    email: "simone.robering@messe.de",
    photo: "/img/team/simoneRobering.webp",
    position: "Senior Project Manager",
  },
];

const contactGroups = [
  {
    title: isSpanish ? "Contactos Nacionales" : "National Contacts",
    description: isSpanish
      ? "Cobertura comercial en todo México"
      : "Sales coverage across Mexico",
    agents: nationalAgents,
  },
  {
    title: isSpanish ? "Contactos Internacionales" : "International Contacts",
    description: isSpanish
      ? "Atención para mercados internacionales"
      : "Support for international markets",
    agents: internationalAgents,
  },
];
---

<section
  class="bg-[url(/img/contac_bg.webp)] bg-no-repeat bg-center bg-cover p-6 sm:py-2 px-4 text-white"
>
  <div class="mx-auto grid grid-cols-1 gap-4 md:grid-cols-2">
    <div
      class="h-auto text-center sm:text-start p-6 sm:p-16 flex flex-col justify-start items-center sm:items-start gap-4"
    >
      <h2 class="font-black text-3xl sm:text-7xl">¡CONTÁCTANOS!</h2>
      <p class="text-white text-lg sm:text-xl md:text-xl lg:text-2xl">
        {
          locale === "es"
            ? "Conecta con nuestro equipo comercial según tu región"
            : "Connect with our sales team according to your region."
        }
      </p>
      <img
        src="/img/smarttecexpo_logo.svg"
        alt="Smart Technology Expo Logo"
        class="w-52 md:w-[500px] mx-auto sm:mx-0 mt-0 sm:mt-36"
        loading="lazy"
        decoding="async"
      />
      <p
        class="text-white text-lg sm:text-xl md:text-xl lg:text-4xl font-semibold uppercase"
      >
        Your business is our business.
      </p>
    </div>

    <div
      class="h-auto grid grid-cols-1 gap-4 md:grid-cols-2"
      data-aos="fade-down"
      data-aos-duration="1500"
      data-aos-delay="300"
    >
      <div class="grid grid-cols-1 gap-6 lg:col-span-2 sm:grid-cols-2">
        {
          contactGroups.map((group) => (
            <article class="sm:p-6">
              <h3 class="text-white text-base md:text-lg font-semibold uppercase tracking-[0.14em] whitespace-pre-line sm:max-w-min">
                {group.title}
              </h3>
              <p class="mt-2 text-white text-sm">{group.description}</p>

              <div class="mt-5 grid grid-cols-1 gap-4">
                {group.agents.map((agent) => (
                  <article class="rounded-2xl border border-white bg-black/10 p-4 transition-colors duration-200 hover:bg-white/10">
                    <div class="flex items-start gap-3">
                      <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full border border-white/25 bg-white/10">
                        <img
                          src={agent.photo}
                          alt={agent.name}
                          class="h-full w-full object-cover"
                        />
                      </div>

                      <div class="min-w-0 flex-1">
                        <p class="text-white text-lg font-extrabold leading-tight">
                          {agent.name}
                        </p>
                        {agent.position && (
                          <p class="mt-1 text-white text-sm sm:text-base">
                            {agent.position}
                          </p>
                        )}
                      </div>
                    </div>

                    <a
                      href={`mailto:${agent.email}`}
                      class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white px-4 py-2.5 text-white text-sm transition-colors duration-200 hover:bg-white hover:text-slate-900"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        class="h-4 w-4 shrink-0"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                        />
                      </svg>
                      <span class="truncate">{agent.email}</span>
                    </a>
                  </article>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
