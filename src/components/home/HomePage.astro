---
// Componente compartido para todas las páginas de inicio
import Welcome from "./Welcome.astro";
import Layout from "../../layouts/Layout.astro";
import { useTranslations, getTranslation } from "../../utils/translations";
import PromotionalVideo from "../shared/PromotionalVideo.astro";
import HeroHome from "./HeroHome.astro";
import Description from "./Description.astro";
import Highlights from "./Highlights.astro";
import { events } from "../../data/constans_events";
import Events from "./Events.astro";
import ContactTeam from "./ContactTeam.astro";
import UserGuideButtons from "./UserGuideButtons.astro";
import HomePopup from '../../components/home/HomePopup.jsx'
import Buyers from "./Buyers.astro";
import CollaboratorsDisplay from "./CollaboratorsDisplay.astro";

export interface Props {
  locale?: string;
}

// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);
// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);
---

<Layout title={tr("site.title", "Smart Technology Expo")} description={tr("site.description", "Expo de tecnología inteligente")}>
  <HomePopup client:load language={locale}/>
  <HeroHome />
  <PromotionalVideo />
  <UserGuideButtons />
  <Description />
  <Highlights />
  <Buyers />
  <CollaboratorsDisplay />
  <!-- <Events events={events} isLeftToRight={true} /> -->
  <ContactTeam />
</Layout>
