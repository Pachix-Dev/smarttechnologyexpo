---
import { useTranslations, getTranslation } from '../../utils/translations'

const { locale, translations } = await useTranslations(Astro.props, Astro)

const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)

const base = locale === 'en' ? '/en' : ''
---

<section class='h-full md:h-screen relative overflow-hidden'>
  <video
    class='w-full h-full absolute top-0 object-cover z-0 animate-fade-in animate-duration-2000'
    muted
    autoplay
    loop
    poster='/img/smart_back.webp'
  >
    <source src='/video/bg_smartexpo.mp4' type='video/mp4' />
    Your browser does not support the video tag.
  </video>

  <div class='absolute inset-0 bg-black/40 z-5'></div>

  <div
    class='container mx-auto py-10 md:py-0 px-4 relative z-10 grid md:flex gap-16 items-center justify-center h-full text-center text-white'
  >
    <div class='animate-fade-up animate-delay-500 animate-duration-1000'>
      <img
        src='/img/smarttecexpo_logo.svg'
        alt='Smart Technology Expo Logo'
        class='mx-auto w-64 md:w-96'
      />
      <p
        class='text-2xl md:text-3xl mt-5 animate-fade-up animate-delay-1000 animate-duration-1000'
      >
        {locale === 'es' ? 'Tu negocio es nuestro negocio.' : 'Your business is our business.'}
      </p>
    </div>

    <div class='animate-fade-left animate-delay-1500 animate-duration-1000'>
      <div>
        <span class='text-3xl md:text-5xl font-bold'>18 - 20</span>
      </div>
      <p
        class='text-3xl md:text-5xl font-extrabold mt-4 animate-fade-up animate-delay-2500 animate-duration-1000'
      >
        {tr('home.month')} 2026
      </p>
      <p
        class='text-3xl animate-fade-up animate-delay-3000 animate-duration-1000 text-gray-200'
      >
        EXPO GUADALAJARA
      </p>
      <a
        href={`${base}/registro`}
        class='group relative mt-8 inline-flex min-w-56 items-center justify-center overflow-hidden rounded-full border-3 border-white bg-red-700 px-8 py-3.5 text-sm font-extrabold uppercase tracking-wide text-white shadow-[0_18px_45px_rgba(0,0,0,0.45)] transition duration-300 hover:-translate-y-1 hover:bg-white hover:text-[#c92520] hover:shadow-[0_24px_60px_rgba(0,0,0,0.55)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-black md:text-base'
      >
        <span class='absolute inset-y-0 left-[-40%] w-1/3 skew-x-[-18deg] bg-white  group-hover:left-[120%]'></span>
        <span class='relative text-base sm:text-2xl'>{locale === 'es' ? 'REGISTRATE AHORA' : 'REGISTER NOW'}</span>
        <svg
          class='ml-3 h-10 w-10 transition duration-300 group-hover:translate-x-1'
          xmlns='http://www.w3.org/2000/svg'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M17 8l4 4m0 0l-4 4m4-4H3'
          />
        </svg>
      </a>
    </div>
  </div>
</section>
