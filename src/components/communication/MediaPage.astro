---
import { useTranslations, getTranslation } from '../../utils/translations'

const { locale, translations } = await useTranslations(Astro.props, Astro)

const tr = (key: string, fallback: string = '') =>
  getTranslation(translations, key, fallback)

const descriptionBlocks = tr('mediaPage.description')
  .split(/<br\s*\/?>/i)
  .map((item) => item.trim())
  .filter(Boolean)

const registerUrl =
  'https://forms.cloud.microsoft/pages/responsepage.aspx?id=NPbrEwntT0iO9-slC7AyJuoXe9rlJXZPmsGakvmyQHhUNVE3SzJEVzdIUFlDWEtUSDk5SzZVWE9DSC4u&route=shorturl'

const registerLabel = locale === 'en' ? 'Register here' : 'Realiza tu registro'
const contactIntro =
  locale === 'en'
    ? 'For questions and more information, please contact us at'
    : 'Para dudas y mas informacion, comuniquese con nosotros en'
---

<section class="bg-white">
  <div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
      <div>
        <p class="mb-3 text-sm font-bold uppercase tracking-[0.22em] text-[#e30613]">
          Smart Technology Expo
        </p>

        <h1 class="max-w-3xl text-4xl font-black uppercase leading-tight text-neutral-950 sm:text-5xl">
          {tr('mediaPage.title')}
        </h1>

        <div class="mt-8 max-w-3xl space-y-5 text-base leading-7 text-neutral-700 sm:text-lg text-justify">
          {
            descriptionBlocks.map((paragraph, index) => (
              <p
                class:list={[
                  index === 0
                    ? ' font-semibold text-neutral-950'
                    : ' text-neutral-700',
                ]}
                set:html={paragraph}
              />
            ))
          }
        </div>
      </div>

      <aside class="rounded-lg border border-neutral-200 bg-neutral-50 p-6 shadow-sm">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-neutral-500">
          {locale === 'en' ? 'Press registration' : 'Registro de prensa'}
        </p>

        <a
          href={registerUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-5 inline-flex w-full items-center justify-center rounded-md bg-[#e30613] px-5 py-3 text-center text-sm font-bold uppercase tracking-wide text-white transition hover:bg-neutral-950 focus:outline-none focus:ring-2 focus:ring-[#e30613] focus:ring-offset-2"
        >
          {registerLabel}
          <span class="ml-2" aria-hidden="true">-&gt;</span>
        </a>

        <div class="mt-7 border-t border-neutral-200 pt-6">
          <p class="text-sm leading-6 text-neutral-600">{contactIntro}</p>
          <a
            href="mailto:social.media@igeco.mx"
            class="mt-3 inline-flex break-all text-base font-bold text-[#062ee3] underline decoration-[#062ee3]/30 underline-offset-4 transition hover:text-neutral-950 hover:decoration-neutral-950"
          >
            social.media@igeco.mx
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>
