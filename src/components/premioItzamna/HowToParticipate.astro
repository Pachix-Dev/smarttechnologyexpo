---
import { useTranslations, getTranslation } from "../../utils/translations";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);
// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);
---

<section
  class="bg-[url(/img/itzamna/itzamna_bg_04.webp)] bg-cover bg-center text-white min-h-screen py-8 sm:py-12 lg:py-16"
>
  <div class="md:px-4 sm:px-6 lg:px-0">
    <div class="flex items-end justify-start lg:justify-end">
      <h2 class="my-6 sm:my-10 lg:my-0 text-2xl sm:text-4xl lg:text-5xl uppercase font-extrabold text-white bg-red-700 ps-5 sm:ps-8 lg:ps-10 py-3 sm:py-4 lg:py-6 w-full max-w-[850px] rounded-l-full">
        {tr("itzamnaPage.participation.title")}
      </h2>
    </div>
    <div class="flex flex-col justify-start items-start gap-6 sm:gap-8 lg:gap-10 max-w-4xl mx-auto px-6">
      <div class="flex flex-col sm:flex-row justify-center items-start sm:items-center gap-4 sm:gap-6">
        <img
          src="/img/itzamna/participate_item_01.webp"
          alt=""
          class="w-16 sm:w-20 lg:w-[100px]"
        />
        <p class="font-extrabold text-lg sm:text-xl lg:text-2xl text-left sm:text-left">
          {tr("itzamnaPage.participation.category01")} <br />
          <span class="font-normal"> {tr("itzamnaPage.participation.description_category01")} </span
          >
        </p>
      </div>
      <div class="flex flex-col sm:flex-row justify-center items-start sm:items-center gap-4 sm:gap-6">
        <img
          src="/img/itzamna/participate_item_02.webp"
          alt=""
          class="w-16 sm:w-20 lg:w-[100px]"
        />
        <p class="font-extrabold text-lg sm:text-xl lg:text-2xl text-left sm:text-left">
          {tr("itzamnaPage.participation.category02")} <br />
          <span class="font-normal"> {tr("itzamnaPage.participation.description_category02")} </span
          >
        </p>
      </div>
      <div class="flex flex-col sm:flex-row justify-center items-start sm:items-center gap-4 sm:gap-6">
        <img src="/img/itzamna/participate_item_03.webp"
          alt=""
          class="w-16 sm:w-20 lg:w-[100px]"/>
        <p class="font-extrabold text-lg sm:text-xl lg:text-2xl text-left sm:text-left">
          {tr("itzamnaPage.participation.category03")} <br />
          <span class="font-normal"> {tr("itzamnaPage.participation.description_category03")} </span
          >
        </p>
      </div>
    </div>
    <div class="flex flex-wrap justify-center gap-4 md:gap-6 pt-8 sm:pt-10">
      <a
        href="https://www.facebook.com/smarttechnologyexpo"
        target="_blank"
        class="transition-all duration-300 hover:scale-110 hover:opacity-80"
        aria-label="Facebook"
        ><svg
          fill="white"
          class="w-6 h-6 md:w-12 md:h-12"
          role="img"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
