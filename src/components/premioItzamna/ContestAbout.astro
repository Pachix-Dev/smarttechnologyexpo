---
import { useTranslations, getTranslation } from "../../utils/translations";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);
// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);
---

<section class="pt-6 sm:pt-10">
  <div class="text-black">
    <h3
      class="text-sm sm:text-2xl lg:text-3xl font-semibold leading-tight text-center italic"
    >
      ITALIAN GERMAN EXHIBITION COMPANY MEXICO
    </h3>
    <h2
      class="text-4xl sm:text-5xl lg:text-7xl font-extrabold leading-tight text-center"
    >
      {tr("itzamnaPage.contestAbout.title")}
    </h2>
    <div
      class="grid md:grid-cols-2 leading-7 p-4 max-w-6xl text-justify mx-auto w-fit sm:pt-10 gap-4"
    >
      <div class="flex flex-col gap-4">
        <p
          class="text-base md:text-xl prose prose-lg text-justify leading-relaxed"
          set:html={tr("itzamnaPage.contestAbout.description")}
        />
        <a
          href="/files/itzamna_2026_convocatoria_18_05_2026.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase inline-flex items-center justify-center rounded-md bg-[#ad2f27] px-5 py-3 text-sm sm:text-base font-semibold text-white transition hover:bg-[#8c251f] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#ad2f27] focus-visible:ring-offset-2 max-w-2xs mx-auto"
        >
          {locale === "en" ? "Download Document" : "Descargar convocatoria"}
        </a>
      </div>
      <div class="flex flex-col items-center gap-4">
        <img
          src="/img/itzamna/convocatoria.webp"
          alt="Convocatoria Premio Itzamna"
          class="w-[450px] rounded-lg mx-auto"
        />
      </div>
    </div>
  </div>
  <!-- participantes -->
  <div
    class="flex flex-col justify-center items-center mt-10 bg-[#ad2f27] text-white px-4 py-4 md:py-10"
  >
    <h3 class="text-4xl lg:text-6xl font-bold leading-tight text-center">
      {tr("itzamnaPage.participants.title")}
    </h3>
    <div
      class="w-full max-w-6xl grid grid-cols-3 gap-2 md:gap-6 mt-8 md:mt-10 justify-items-center"
    >
      <div
        class="min-h-[150px] md:min-h-[220px] w-full max-w-[280px] bg-black/40 flex flex-col justify-center items-center text-center rounded-lg md:rounded-xl p-2 md:p-3 text-[11px] leading-4 md:text-base md:leading-6"
      >
        <img
          src="/img/itzamna/icono_01.webp"
          alt=""
          class="w-10 md:w-[130px]"
        />
        {tr("itzamnaPage.participants.item01")}
      </div>
      <div
        class="min-h-[150px] md:min-h-[220px] w-full max-w-[280px] bg-black/40 flex flex-col justify-center items-center text-center rounded-lg md:rounded-xl p-2 md:p-3 text-[11px] leading-4 md:text-base md:leading-6"
      >
        <img
          src="/img/itzamna/icono_02.webp"
          alt=""
          class="w-10 md:w-[130px]"
        />
        {tr("itzamnaPage.participants.item02")}
      </div>
      <div
        class="min-h-[150px] md:min-h-[220px] w-full max-w-[280px] bg-black/40 flex flex-col justify-center items-center text-center rounded-lg md:rounded-xl p-2 md:p-3 text-[11px] leading-4 md:text-base md:leading-6"
      >
        <img
          src="/img/itzamna/icono_03.webp"
          alt=""
          class="w-10 md:w-[130px]"
        />
        {tr("itzamnaPage.participants.item03")}
      </div>
      <div
        class="min-h-[150px] md:min-h-[220px] w-full max-w-[280px] bg-black/40 flex flex-col justify-center items-center text-center rounded-lg md:rounded-xl p-2 md:p-3 text-[11px] leading-4 md:text-base md:leading-6"
      >
        <img
          src="/img/itzamna/icono_04.webp"
          alt=""
          class="w-10 md:w-[130px]"
        />
        {tr("itzamnaPage.participants.item04")}
      </div>
      <div
        class="min-h-[150px] md:min-h-[220px] w-full max-w-[280px] bg-black/40 flex flex-col justify-center items-center text-center rounded-lg md:rounded-xl p-2 md:p-3 text-[11px] leading-4 md:text-base md:leading-6"
      >
        <img
          src="/img/itzamna/icono_05.webp"
          alt=""
          class="w-10 md:w-[130px]"
        />
        {tr("itzamnaPage.participants.item05")}
      </div>
      <div
        class="min-h-[150px] md:min-h-[220px] w-full max-w-[280px] bg-black/40 flex flex-col justify-center items-center text-center rounded-lg md:rounded-xl p-2 md:p-3 text-[11px] leading-4 md:text-base md:leading-6"
      >
        <img
          src="/img/itzamna/icono_06.webp"
          alt=""
          class="w-10 md:w-[130px]"
        />
        {tr("itzamnaPage.participants.item06")}
      </div>
    </div>
  </div>
</section>
