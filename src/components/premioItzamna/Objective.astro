---
import { useTranslations, getTranslation } from "../../utils/translations";
// ✨ Una sola línea para cargar traducciones!
const { locale, translations } = await useTranslations(Astro.props, Astro);
// 🎯 Helper para traducciones más elegante
const tr = (key: string, fallback: string = "") =>
  getTranslation(translations, key, fallback);

const objectiveCards = [
  {
    key: "itzamnaPage.objectives.item01",
    es: "Incrementar productividad y competitividad",
    en: "Increase productivity and competitiveness",
    img : "/img/itzamna/persons.webp",
  },
  {
    key: "itzamnaPage.objectives.item02",
    es: "Optimizar procesos industriales",
    en: "Optimize industrial processes",
    img : "/img/itzamna/man_work.webp",
  },
  {
    key: "itzamnaPage.objectives.item03",
    es: "Impulsar transformación digital",
    en: "Drive digital transformation",
    img : "/img/itzamna/robotMan.webp",
  },
  {
    key: "itzamnaPage.objectives.item04",
    es: "Mejorar eficiencia energética y sostenibilidad",
    en: "Improve energy efficiency and sustainability",
    img : "/img/itzamna/house_person.webp",
  },
  {
    key: "itzamnaPage.objectives.item05",
    es: "Fortalecer cadenas productivas",
    en: "Strengthen supply chains",
    img : "/img/itzamna/person_industri.webp",
  },
  {
    key: "itzamnaPage.objectives.item06",
    es: "Promover innovación escalable en el sector industrial",
    en: "Promote scalable innovation in the industrial sector",
    img : "/img/itzamna/person_learning.webp",
  },
];

const callStages = [
  {
    titleKey: "itzamnaPage.callStages.stage01.title",
    esTitle: "Registro de proyectos",
    enTitle: "Project registration",
    dateKey: "itzamnaPage.callStages.stage01.date",
    esDate: "15 de mayo al 4 de septiembre",
    enDate: "May 15 to September 4",
  },
  {
    titleKey: "itzamnaPage.callStages.stage02.title",
    esTitle: "Evaluación",
    enTitle: "Evaluation",
    dateKey: "itzamnaPage.callStages.stage02.date",
    esDate: "11 de septiembre al 10 de octubre",
    enDate: "September 11 to October 10",
  },
  {
    titleKey: "itzamnaPage.callStages.stage03.title",
    esTitle: "Anuncio de finalistas",
    enTitle: "Finalists announcement",
    dateKey: "itzamnaPage.callStages.stage03.date",
    esDate: "20 de octubre",
    enDate: "October 20",
  },
  {
    titleKey: "itzamnaPage.callStages.stage04.title",
    esTitle: "Ceremonia de premiación",
    enTitle: "Awards ceremony",
    dateKey: "itzamnaPage.callStages.stage04.date",
    esDate: "17 de noviembre",
    enDate: "November 17",
  },
];
---
<section class="relative overflow-hidden py-12 md:py-16">
  <div class="absolute inset-0 bg-linear-to-br from-[#0f2f75] via-[#1f4ea8] to-[#2f6fd4]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 md:px-6 text-white">
    <h3 class="text-3xl sm:text-4xl lg:text-6xl font-bold text-center mt-2 md:mt-4">
      {tr("itzamnaPage.objectives.title")}
    </h3>
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-center mt-4 md:mt-6 ">
      <!-- {tr("itzamnaPage.objectives.title", locale === "en" ? "Main Objectives" : "Objetivos principales")} -->
       {tr("itzamnaPage.objectives.description")}
    </h2>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-5 md:gap-7 mt-8 md:mt-12">
      {
        objectiveCards.map((card) => {
          const fallbackText = locale === "en" ? card.en : card.es;
          return (
            <article class="w-full max-w-[180px] sm:max-w-none mx-auto rounded-xl md:rounded-2xl overflow-hidden bg-white/10 shadow-[0_10px_24px_rgba(0,0,0,0.28)] md:shadow-[0_16px_35px_rgba(0,0,0,0.32)] backdrop-blur-[1px]">
              <img
                src={card.img}
                alt={tr(card.key, fallbackText)}
                class="w-full h-[145px] sm:h-[200px] md:h-[260px] object-cover"
                loading="lazy"
              />
              <div class="bg-[#c9202c] px-2 sm:px-4 py-2 sm:py-4 min-h-16 sm:min-h-[86px] flex items-center justify-center">
                <p class="text-center text-sm sm:text-base md:text-lg font-semibold leading-tight">
                  {tr(card.key, fallbackText)}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>

  <!-- etapas de convocatoria -->
  <div class="relative z-10 max-w-6xl mx-auto px-4 md:px-6 mt-12 md:mt-24 text-white">
      <h4 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-center">
        {tr(
          "itzamnaPage.callStages.title",
          locale === "en" ? "Call for projects timeline" : "Etapas de convocatoria"
        )}
      </h4>

      <div class="mt-8 lg:hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            callStages.map((stage) => {
              const fallbackTitle = locale === "en" ? stage.enTitle : stage.esTitle;
              const fallbackDate = locale === "en" ? stage.enDate : stage.esDate;

              return (
                <article class="rounded-xl bg-white/10 p-4 shadow-[0_10px_24px_rgba(0,0,0,0.25)]">
                  <div class="inline-flex min-h-14 w-full items-center justify-center rounded-lg bg-[#d50c20] px-3 py-3 text-base font-bold leading-tight text-center">
                    {tr(stage.titleKey, fallbackTitle)}
                  </div>
                  <div class="mt-4 flex items-center justify-center gap-0 sm:gap-3">
                    <div class="hidden h-4 w-4 rounded-full border-[3px] border-[#d7dff7] bg-[#355ea8] shadow-[0_0_0_3px_rgba(30,67,138,0.55)] sm:block"></div>
                    <p class="text-lg font-bold leading-tight text-white text-center">
                      {tr(stage.dateKey, fallbackDate)}
                    </p>
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>

      <div class="hidden lg:block mt-10">
        <div class="grid grid-cols-4 gap-6">
          {
            callStages.map((stage) => {
              const fallbackTitle = locale === "en" ? stage.enTitle : stage.esTitle;

              return (
                <div class="text-center">
                  <div class="inline-flex min-h-16 w-full items-center justify-center rounded-xl bg-[#d50c20] px-3 py-3 text-lg font-bold leading-tight shadow-[0_10px_24px_rgba(0,0,0,0.25)]">
                    {tr(stage.titleKey, fallbackTitle)}
                  </div>
                </div>
              );
            })
          }
        </div>

        <div class="relative mt-9">
          <div class="absolute left-[12.5%] right-[12.5%] top-2.5 h-[5px] rounded-full bg-white/90"></div>

          <div class="relative grid grid-cols-4 gap-6">
            {
              callStages.map((stage) => {
                const fallbackDate = locale === "en" ? stage.enDate : stage.esDate;

                return (
                  <div class="text-center">
                    <div class="mx-auto h-0 w-0 sm:h-5 sm:w-5 rounded-full border-[3px] border-[#d7dff7] bg-[#3554a8] shadow-[0_0_0_3px_rgba(30,67,138,0.55)]"></div>
                    <p class="mt-4 text-2xl font-bold leading-tight text-white text-center">
                      {tr(stage.dateKey, fallbackDate)}
                    </p>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
  </div>

</section>