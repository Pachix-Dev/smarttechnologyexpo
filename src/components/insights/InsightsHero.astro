---
// InsightsHero.astro — Header/switcher + hero for the SMART INSIGHTS (Conferencias) interior.
import HeaderSwitcher from '../shared/HeaderSwitcher.astro';
import { useTranslations, getTranslation } from "../../utils/translations";

export interface Chip {
  label: string;
  value: string;
}

export interface Props {
  eyebrow?: string;
  title1?: string;
  title2?: string;
  description?: string;
  chips?: Chip[];
  logoSrc?: string;
}

const { translations, locale } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = "") => getTranslation(translations, key, fallback);

const {
  eyebrow = tr('insights.hero.eyebrow', 'ESCENARIO PRINCIPAL'),
  title1 = 'Smart',
  title2 = 'Insights',
  description = tr('insights.hero.description', 'Contenido estratégico para líderes que impulsan el rumbo de la industria. Conferencias magistrales y paneles de discusión sobre las fuerzas que redefinen los mercados, la innovación y el futuro de los negocios.'),
  chips = [
    { label: tr('insights.hero.chip1_label', 'FECHAS'), value: tr('insights.hero.chip1_value', '18 – 20 Nov 2026') },
    { label: tr('insights.hero.chip2_label', 'SEDE'), value: tr('insights.hero.chip2_value', 'Expo Guadalajara, Jalisco') },
    { label: tr('insights.hero.chip3_label', 'FORMATO'), value: tr('insights.hero.chip3_value', 'Conferencias magistrales y paneles') },
  ],
  logoSrc,
} = Astro.props;
---

<HeaderSwitcher active="conferencias" logoSrc={logoSrc} />

<section class="ih-hero">
  <div class="ih-dots" aria-hidden="true"></div>
  <div class="ih-glow" aria-hidden="true"></div>

  <div class="ih-inner">
    <div class="ih-eyebrow">
      <span class="ih-eyebrow-line"></span>
      <span class="ih-eyebrow-text">{eyebrow}</span>
    </div>

    <h1 class="ih-title">
      <span class="ih-title-a">{title1}</span><br />
      <span class="ih-title-b">{title2}</span>
    </h1>

    <p class="ih-description">{description}</p>

    <div class="ih-chips">
      {chips.map((chip) => (
        <div class="ih-chip">
          <span class="ih-chip-label">{chip.label}</span>
          <span class="ih-chip-value">{chip.value}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ih-hero {
    position: relative;
    background: #000;
    overflow: hidden;
    border-bottom: 1px solid #161616;
    font-family: 'Archivo', Helvetica, Arial, sans-serif;
    color: #fff;
  }

  .ih-dots {
    position: absolute;
    inset: 0;
    background-image: repeating-radial-gradient(circle at 78% 42%, #161616 0 1px, transparent 1px 26px);
    opacity: 0.9;
  }

  .ih-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 78% 42%, rgba(226, 16, 26, 0.16), transparent 46%);
  }

  .ih-inner {
    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(48px, 9vw, 104px) clamp(16px, 4vw, 40px) clamp(40px, 7vw, 80px);
  }

  .ih-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 22px;
  }

  .ih-eyebrow-line {
    width: 30px;
    height: 2px;
    background: #e2101a;
  }

  .ih-eyebrow-text {
    font-size: 12px;
    letter-spacing: 0.3em;
    font-weight: 700;
    color: #fff;
  }

  .ih-title {
    margin: 0;
    font-size: clamp(52px, 11vw, 128px);
    line-height: 0.9;
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .ih-title-a {
    color: #fff;
    text-shadow:
      0 0 2px  #fff,
      0 0 6px  #fff,
      0 0 12px rgba(255, 255, 255, 0.55),
      0 0 24px rgba(255, 255, 255, 0.35),
      0 0 48px rgba(255, 255, 255, 0.2);
  }

  .ih-title-b {
    color: #4a3636;
  text-shadow:
    0 0 6px  rgba(74, 54, 54, 0.9),
    0 0 16px rgba(74, 54, 54, 0.5);
  }

  .ih-description {
    margin: 26px 0 0;
    max-width: 640px;
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.55;
    color: #b9b9b9;
    text-wrap: pretty;
  }

  .ih-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .ih-chip {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 20px;
    background: #0d0d0d;
    border: 1px solid #1e1e1e;
    border-radius: 5px;
    min-width: 150px;
  }

  .ih-chip-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: #777;
  }

  .ih-chip-value {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
  }
</style>