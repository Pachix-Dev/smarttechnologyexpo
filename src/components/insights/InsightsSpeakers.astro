---
// InsightsSpeakers.astro — Wrapper: monta la isla React con la grid de Keynote Speakers
// construida DESDE LA API (ponentes únicos del escenario) y le pasa los textos de
// interfaz desde tus locales (tr / getTranslation). La semblanza sale de bio_esp/bio_eng.
import InsightsSpeakersLive from './InsightsSpeakersLive.jsx';
import './insights.css';
import { useTranslations, getTranslation } from '../../utils/translations';

export interface Props {
  stageId?: number;
}

const { translations, locale } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = '') => getTranslation(translations, key, fallback);

const { stageId } = Astro.props;
const lang = locale === 'en' ? 'en' : 'es';

const labels = {
  eyebrow: tr('insights.speakers.eyebrow', 'PONENTES DESTACADOS'),
  title: tr('insights.speakers.title', 'Keynote Speakers'),
  note: tr('insights.speakers.note', 'Programa preliminar · sujeto a cambios'),
  photo: tr('insights.speakers.photo', 'foto ponente'),
  bioBtn: tr('insights.speakers.bio_btn', 'VER SEMBLANZA'),
};
---

<InsightsSpeakersLive client:only="react" lang={lang} stageId={stageId} labels={labels} />