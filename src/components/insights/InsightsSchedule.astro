---
// InsightsSchedule.astro — Wrapper: monta la isla React que trae el PROGRAMA EN VIVO
// desde la API (elige title/title_en, description/description_en según idioma, como
// Ecomondo) y le pasa los textos de interfaz desde tus locales (tr / getTranslation).
import InsightsScheduleLive from './InsightsScheduleLive.jsx';
import './insights.css';
import { useTranslations, getTranslation } from '../../utils/translations';

export interface Props {
  stageId?: number;   // opcional: fuerza un escenario concreto
  pdfHref?: string;   // opcional: link del PDF de descarga
}

const { translations, locale } = await useTranslations(Astro.props, Astro);
const tr = (key: string, fallback: string = '') => getTranslation(translations, key, fallback);

const { stageId, pdfHref = '#' } = Astro.props;
const lang = locale === 'en' ? 'en' : 'es';

const labels = {
  eyebrow: tr('insights.schedule.eyebrow', 'AGENDA'),
  title: tr('insights.schedule.title', 'Programa por día'),
  sub: tr('insights.schedule.sub', 'Selecciona un día para ver las conferencias, paneles y horarios.'),
  dlLabel: tr('insights.schedule.dl_label', 'DESCARGA GRATUITA'),
  dlBtn: tr('insights.schedule.dl_btn', 'DESCARGA PROGRAMA'),
  notice: tr('insights.schedule.notice', 'Todas las ponencias se realizarán en español.'),
  selectDay: tr('insights.schedule.select_day', 'SELECCIONA EL DÍA'),
  sessionsWord: tr('insights.schedule.sessions_word', 'sesiones'),
  speakersWord: tr('insights.schedule.speakers_word', 'Ponentes'),
  speakerWord: tr('insights.schedule.speaker_word', 'Ponente'),
  legendConference: tr('insights.schedule.legend_conference', 'Conferencia'),
  legendBreak: tr('insights.schedule.legend_break', 'Receso'),
  badges: {
    keynote: tr('insights.schedule.badge_keynote', 'KEYNOTE'),
    panel: tr('insights.schedule.badge_panel', 'PANEL'),
    conference: tr('insights.schedule.badge_conference', 'CONFERENCIA'),
    break: tr('insights.schedule.badge_break', 'RECESO'),
  },
};
---

<InsightsScheduleLive
  client:only="react"
  lang={lang}
  stageId={stageId}
  pdfHref={pdfHref}
  labels={labels}
/>